# ──────────────────────────────────────────────────────────────────────────
# Amanahku — PRODUCTION environment template
# Copy to `.env` on the production host, then fill real secrets. NEVER commit the
# filled file. Generate APP_KEY with: php artisan key:generate
# Owner: Unijaya Resources Sdn Bhd
# ──────────────────────────────────────────────────────────────────────────

APP_NAME=Amanahku
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://amanahku.example        # ← real production domain

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# ── Database (Hostinger naming: u_<account>_<db>) ─────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=amanahku_prod                # ← real prod DB (e.g. u_unijaya_amanahku)
DB_USERNAME=amanahku                      # ← real prod DB user
DB_PASSWORD=__set_a_strong_password__

# ── Session / security ────────────────────────────────────────────────────
# Database-backed sessions survive deploys; secure + encrypted cookies over TLS.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# Leave null so the cookie binds to whatever host serves the request. A hardcoded
# domain that doesn't match the real host makes the browser drop the session cookie
# → login authenticates but never sticks. Only set an explicit value to share
# sessions across subdomains (e.g. .yourdomain.com).
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ── Cache & queue ─────────────────────────────────────────────────────────
# Invite + verification + digest emails are queued (ShouldQueue). A worker MUST run:
#   php artisan queue:work --tries=3 --max-time=3600   (supervise with systemd/supervisor/cron)
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# ── Mail (real SMTP — required for invites, resets, weekly digest) ─────────
MAIL_MAILER=smtp
MAIL_HOST=__smtp_host__
MAIL_PORT=587
MAIL_USERNAME=__smtp_user__
MAIL_PASSWORD=__smtp_password__
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="noreply@amanahku.example"
MAIL_FROM_NAME="${APP_NAME}"

# ── Logging (quieter in prod) ─────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=error

# ── OIDC SSO (optional — leave blank to disable) ──────────────────────────
OIDC_AUTHORIZE_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_REDIRECT_URL=
