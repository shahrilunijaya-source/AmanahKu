# PRODUCTION: APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-host,
# run `php artisan key:generate` to fill APP_KEY. Never deploy with APP_DEBUG=true.
APP_NAME=Amanahku
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# PRODUCTION (AK-CONFIG-03): set LOG_STACK=daily (rotated files, not one unbounded
# file) and LOG_LEVEL=warning (debug/info floods disk and can leak request detail).
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=amanahku
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# PRODUCTION: leave unset to default ON in production, or force =true. Keeps the
# session cookie from ever being sent over plain HTTP (AK-SEC-09).
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Dev default writes mail (password-reset + invite links) to storage/logs/laravel.log.
# PRODUCTION (I-009): set MAIL_MAILER=smtp (or ses) and real credentials so reset and
# invite emails actually send. Example SMTP block:
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.your-provider.com
#   MAIL_PORT=587
#   MAIL_SCHEME=tls
#   MAIL_USERNAME=your-smtp-user
#   MAIL_PASSWORD=your-smtp-secret
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@amanahku.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Workforce assistant. "canned" (default) summarises live data with no external calls.
# Set to "claude" and provide ANTHROPIC_API_KEY to enable conversational AI answers.
AMANAHKU_AI_DRIVER=canned
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Enterprise single sign-on (OpenID Connect, authorization-code flow).
# SSO is OFF until client id/secret and all three endpoints are set; then the
# "Sign in with SSO" button appears on the login screen. SSO can create a
# tenant-less account but never grants a tenant, role, or super-admin.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=
OIDC_AUTHORIZE_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_REDIRECT_URL=
OIDC_SCOPES="openid email profile"
